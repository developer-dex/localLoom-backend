NODE_ENV=development
PORT=5000
API_PREFIX=/api

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=localloom_dev
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

# Uploads
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Network IP (for Swagger & mobile testing — change to your WiFi IP, leave empty to disable)
SERVER_HOST=

# Twilio (SMS OTP) — required in production, optional in development
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid

# OTP Config
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_DEV_CODE=123456

# Email (SMTP OTP) — optional; absence triggers dev mode (OTP logged to console)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@localloom.com.au

# ABN Lookup (Australian Business Register — get GUID from https://abr.business.gov.au/Tools/WebServices)
ABN_LOOKUP_GUID=

# AI Classifier (Anthropic Claude) — required for /api/v1/ai/classify-service
# AI_MODE: "development" skips Anthropic calls and returns random category/region IDs.
#           "production" uses the real Anthropic API.
AI_MODE=development
# API key for Anthropic. Endpoint returns 503 when unset in production mode.
ANTHROPIC_API_KEY=
# Model identifier. Default uses the cheap, fast Haiku tier.
ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5
# Max token budget per classify call. 256 is plenty for the JSON response.
AI_CLASSIFIER_MAX_TOKENS=256
# Temperature: 0 = fully deterministic. Increase for diversity on JSON retries.
AI_CLASSIFIER_TEMPERATURE=0
# Anthropic API call timeout in milliseconds.
AI_CLASSIFIER_TIMEOUT_MS=15000
# Per-authenticated-user rate limit: max requests within the window.
AI_CLASSIFIER_RATE_LIMIT_MAX=30
# Rate limit sliding window in milliseconds.
AI_CLASSIFIER_RATE_LIMIT_WINDOW_MS=60000
# In-memory TTL (ms) for the active categories+regions catalog. 0 disables cache.
AI_CLASSIFIER_CATALOG_CACHE_TTL_MS=60000
# Set to true to log full user prompts at DEBUG level (PII risk; off by default).
AI_CLASSIFIER_DEBUG_LOG_PROMPT=false
